{
  "name": "ios-win-integration",
  "version": "3.6.0",
  "description": "Send images and text from iPhone to PC over local network via iOS Shortcuts",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder build --win"
  },
  "dependencies": {
    "clipboardy": "^4.0.0",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.2",
    "node-notifier": "^10.0.1",
    "qrcode": "^1.5.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.asep-ios-integration.airodrop",
    "productName": "AiroDrop",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/logo.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "public/logo.png"
    },
    "extraResources": [
      {
        "from": "node_modules/node-notifier/vendor",
        "to": "vendor"
      }
    ]
  }
}
